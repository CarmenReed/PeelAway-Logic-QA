{
  "name": "peelaway-logic",
  "version": "4.0.0",
  "description": "AI-powered job search pipeline: Scout, Review, Tailor",
  "homepage": "https://carmenreed.github.io/PeelAway-Logic-QA",
  "private": true,
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "deploy": "gh-pages -d build",
    "test:e2e": "npx playwright test",
    "test:e2e:ui": "npx playwright test --ui",
    "test:e2e:headed": "npx playwright test --headed",
    "hci-audit": "node scripts/hci-audit.js",
    "docs-sync": "node scripts/docs-sync.js",
    "promote": "node scripts/promote.js",
    "promote:apply": "node scripts/promote.js --apply",
    "promote:ship": "node scripts/generate-repo-map.js && node scripts/promote.js --apply --commit --push"
  },
  "dependencies": {
    "core-js-pure": "^3.37.1",
    "lodash": "^4.17.21",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-scripts": "5.0.1"
  },
  "overrides": {
    "lodash": "^4.17.21"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.0",
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "gh-pages": "^6.3.0",
    "jest-axe": "^9.0.0",
    "wait-on": "^9.0.5"
  }
}
