{
  "_comment": "Promotion config — read by PROD scripts to understand QA structure. Update this file when QA changes.",

  "neverPromote": {
    "dirs": [".git", ".claude", "node_modules", ".venv", "__pycache__", "build", "playwright-report", "test-results", "PeelAway Logic", "docs/hci-audit/flags"],
    "files": [".env", "claude-code-entry-point.md", "fix-failing-tests.ps1", "prod-update-docs.yml", "MASTER_PLAN_*", "*sprint-plan*", "POST_RESKIN_DECOMPOSITION_PLAN.md", "promotion-manifest.md"],
    "rootFileExtensions": [".ps1"]
  },

  "preserveProdVersions": ["CLAUDE.md", "docs/GITHUB-KNOWLEDGE-BASE.md"],

  "_alwaysPromoteComment": "Paths listed here override neverPromote. The promotion script copies these even if an ancestor directory is in neverPromote.dirs.",
  "alwaysPromote": {
    "paths": []
  },

  "alwaysExcludeFromCopy": {
    "filePatterns": ["*.pyc", "*.bak", "*.tmp", "*.orig", "*.old", ".DS_Store", "Thumbs.db"]
  },

  "envReplacements": {
    "PeelAway-Logic-QA": "PeelAway-Logic",
    "the QA repo": "this repository",
    "QA repo": "this repository",
    "QA branch": "main branch",
    "QA environment": "production environment"
  },

  "envReplacementFileTypes": ["*.md", "*.js", "*.jsx", "*.ts", "*.tsx", "*.json", "*.yml", "*.yaml", "*.html"],

  "_envReplacementExclusionsComment": "Files that legitimately discuss the QA/PROD relationship. Excluded from BOTH env replacement AND env audit.",
  "envReplacementExclusions": [".promotion.json", "CLAUDE.md", "scripts/promote.js"],

  "envAuditPatterns": [
    { "pattern": "PeelAway-Logic-QA", "flags": "i", "label": "PeelAway-Logic-QA" },
    { "pattern": "\\bQA repo\\b", "flags": "i", "label": "QA repo" },
    { "pattern": "\\bQA branch\\b", "flags": "i", "label": "QA branch" },
    { "pattern": "\\bQA environment\\b", "flags": "i", "label": "QA environment" },
    { "pattern": "Quality Assurance", "flags": "i", "label": "Quality Assurance (full phrase)" },
    { "pattern": "\\bQA copy\\b", "flags": "i", "label": "QA copy" },
    { "pattern": "\\bQA validation\\b", "flags": "i", "label": "QA validation" },
    { "pattern": "\\bQA validates\\b", "flags": "i", "label": "QA validates" },
    { "pattern": "\\bstaging ground\\b", "flags": "i", "label": "staging ground" }
  ],

  "packageJson": {
    "preserveFromProd": ["homepage"]
  },

  "prePromotionChecks": [
    "npm test",
    "node scripts/doc-lint.js"
  ],

  "ecosystemSync": {
    "ecosystemRelativePath": "../AI-Claude-Code-Ecosystem",
    "scanExtensions": [".md", ".mermaid"],
    "excludeDirs": [".git", "node_modules", ".claude", "build", "playwright-report", "test-results"],
    "ecosystemScope": "peelaway-logic/",
    "sourceInventory": {
      "docs": "docs/",
      "workflows": ".github/workflows/",
      "scripts": "scripts/",
      "tests": "src/__tests__/",
      "e2e": "e2e/",
      "adrs": "docs/architecture/decisions/"
    }
  },

  "cleanupHints": {
    "emptyDirs": true,
    "buildArtifacts": ["build", "playwright-report", "test-results"],
    "staleOneOffScripts": ["fix-failing-tests.ps1", "prod-update-docs.yml"],
    "relocate": {
      "POST_RESKIN_DECOMPOSITION_PLAN.md": "docs/architecture/DECOMPOSITION_PLAN.md"
    }
  }
}
